<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>LASFORLIFE — Central de Congressos</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css"/>
<style>
.topbar{background:#1e2235;padding:13px 20px;display:flex;align-items:center;}
.brand-name{font-size:16px;font-weight:500;color:#fff;letter-spacing:2px;}
.brand-name em{font-style:normal;font-weight:300;opacity:.75;}
.brand-tag{font-size:9px;color:rgba(255,255,255,.45);letter-spacing:.3px;margin-top:2px;}
.app{max-width:900px;margin:0 auto;}
.screen{display:none;}.screen.active{display:block;}
.home-hero{background:linear-gradient(135deg,#1565c0 0%,#1976d2 60%,#29b6f6 100%);border-bottom:1px solid rgba(255,255,255,.1);padding:22px 20px 18px;}
.home-eyebrow{font-size:10px;letter-spacing:2px;color:#ffc107;text-transform:uppercase;margin-bottom:7px;font-weight:600;}
.home-title{font-size:20px;font-weight:500;color:#fff;margin-bottom:3px;}
.home-sub{font-size:12px;color:rgba(255,255,255,.75);}
.filter-row{display:flex;gap:6px;margin-top:14px;overflow-x:auto;scrollbar-width:none;padding-bottom:2px;}
.filter-row::-webkit-scrollbar{display:none;}
.filter-pill{font-size:11px;font-weight:500;padding:5px 14px;border-radius:20px;border:1px solid rgba(255,255,255,.35);background:rgba(255,255,255,.12);color:rgba(255,255,255,.85);cursor:pointer;white-space:nowrap;}
.filter-pill.active{background:#ffc107;border-color:#ffc107;color:#1e2235;font-weight:600;}
.events-wrap{padding:16px 20px;display:flex;flex-direction:column;gap:10px;background:#f0f4f8;}
.event-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;overflow:hidden;cursor:pointer;transition:border-color .15s;}
.event-card:hover{border-color:#29b6f6;}
.ec-inner{display:flex;}.ec-accent{width:5px;flex-shrink:0;}
.ec-main{flex:1;padding:14px 16px;}
.ec-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:8px;}
.ev-status{font-size:10px;font-weight:600;padding:3px 9px;border-radius:20px;}
.s-ativo{background:#e8f5e9;color:#2e7d32;border:1px solid #a5d6a7;}
.s-proximo{background:#e3f2fd;color:#1565c0;border:1px solid #90caf9;}
.s-enc{background:#f5f5f5;color:#757575;border:1px solid #e0e0e0;}
.ec-arrow{color:#b0bec5;font-size:14px;}
.ec-name{font-size:14px;font-weight:500;color:#1a237e;line-height:1.35;margin-bottom:10px;}
.ec-meta{display:flex;flex-direction:column;gap:3px;}
.ec-meta-row{display:flex;align-items:center;gap:6px;font-size:11px;color:#607d8b;}
.ec-meta-row i{font-size:12px;color:#90a4ae;}
.ec-footer{display:flex;align-items:center;justify-content:space-between;margin-top:12px;padding-top:10px;border-top:1px solid #f0f4f8;}
.leads-lbl{font-size:10px;color:#90a4ae;}.leads-val{font-size:13px;font-weight:500;color:#1a237e;}
.prog{height:4px;background:#e3f2fd;border-radius:2px;width:72px;overflow:hidden;margin-top:3px;}
.prog-fill{height:100%;border-radius:2px;}
.open-btn{font-size:11px;font-weight:600;color:#1976d2;display:flex;align-items:center;gap:4px;}
.detail-topbar{background:#1e2235;padding:11px 20px;display:flex;align-items:center;gap:12px;}
.back-btn{display:flex;align-items:center;gap:6px;font-size:12px;font-weight:500;color:rgba(255,255,255,.7);background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);padding:6px 12px;border-radius:20px;cursor:pointer;}
.detail-ev-name{font-size:13px;font-weight:500;color:rgba(255,255,255,.85);flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.tab-bar{background:#fff;border-bottom:2px solid #e3f2fd;padding:0 20px;display:flex;overflow-x:auto;scrollbar-width:none;gap:2px;}
.tab-bar::-webkit-scrollbar{display:none;}
.tab-btn{padding:11px 13px;font-size:11px;font-weight:500;color:#90a4ae;border:none;background:none;border-bottom:2.5px solid transparent;white-space:nowrap;cursor:pointer;display:flex;align-items:center;gap:5px;flex-shrink:0;}
.tab-btn i{font-size:13px;}.tab-btn.active{color:#1976d2;border-bottom-color:#1976d2;font-weight:600;}
.tab-content{padding:18px 20px;display:none;background:#f0f4f8;}.tab-content.active{display:block;}
.hero-block{background:linear-gradient(135deg,#1565c0 0%,#1976d2 60%,#29b6f6 100%);border-radius:14px;padding:18px;margin-bottom:14px;}
.hero-eyebrow{font-size:9px;letter-spacing:2px;color:#ffc107;text-transform:uppercase;margin-bottom:5px;font-weight:600;}
.hero-name{font-size:17px;font-weight:500;color:#fff;line-height:1.3;margin-bottom:11px;}
.hero-pills{display:flex;flex-wrap:wrap;gap:6px;}
.hpill{font-size:10px;padding:3px 10px;border-radius:20px;font-weight:500;border:1px solid;}
.hp-g{background:rgba(76,175,80,.2);color:#c8e6c9;border-color:rgba(76,175,80,.35);}
.hp-b{background:rgba(255,255,255,.15);color:#fff;border-color:rgba(255,255,255,.3);}
.hp-y{background:rgba(255,193,7,.2);color:#ffc107;border-color:rgba(255,193,7,.4);}
.stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:8px;margin-bottom:14px;}
.stat{background:#fff;border:1px solid #e3f2fd;border-radius:10px;padding:11px 13px;border-top:3px solid #29b6f6;}
.stat-lbl{font-size:9px;letter-spacing:.8px;text-transform:uppercase;color:#90a4ae;margin-bottom:3px;}
.stat-val{font-size:17px;font-weight:600;color:#1a237e;}.stat-sub{font-size:10px;color:#90a4ae;margin-top:1px;}
.iblock{background:#fff;border:1px solid #e3f2fd;border-radius:10px;padding:13px 15px;margin-bottom:8px;border-left:4px solid #29b6f6;}
.iblock-head{font-size:11px;font-weight:600;color:#607d8b;margin-bottom:5px;display:flex;align-items:center;gap:6px;}
.iblock-head i{font-size:13px;color:#1976d2;}.iblock-body{font-size:12px;color:#263238;line-height:1.75;}
.ag-list{display:flex;flex-direction:column;gap:7px;}
.ag-item{background:#fff;border:1px solid #e3f2fd;border-radius:10px;padding:11px 14px;display:flex;gap:12px;align-items:flex-start;}
.ag-day{background:#1976d2;color:#fff;font-size:10px;font-weight:600;padding:4px 8px;border-radius:6px;white-space:nowrap;text-align:center;line-height:1.5;min-width:56px;flex-shrink:0;}
.ag-title{font-size:12px;font-weight:600;color:#1a237e;margin-bottom:3px;}
.ag-loc{font-size:11px;color:#607d8b;display:flex;align-items:center;gap:4px;}.ag-loc i{font-size:11px;}
.mbadge{display:inline-block;font-size:10px;padding:1px 7px;border-radius:20px;margin-left:5px;font-weight:600;}
.mb-g{background:#e8f5e9;color:#2e7d32;}.mb-b{background:#e3f2fd;color:#1565c0;}
.mb-y{background:#fff8e1;color:#f57f17;}.mb-p{background:#f3e5f5;color:#6a1b9a;}
.mat-cat{font-size:10px;letter-spacing:.8px;text-transform:uppercase;color:#90a4ae;margin:14px 0 7px 2px;font-weight:600;}
.file-list{display:flex;flex-direction:column;gap:6px;}
.file-row{background:#fff;border:1px solid #e3f2fd;border-radius:10px;padding:10px 14px;display:flex;align-items:center;gap:11px;}
.ficon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.fi-pdf{background:#fce4ec;color:#c62828;}.fi-ppt{background:#fff3e0;color:#e65100;}
.fi-xls{background:#e8f5e9;color:#2e7d32;}.fi-vid{background:#e3f2fd;color:#1565c0;}
.fi-doc{background:#e0f7fa;color:#00695c;}.fi-zip{background:#ede7f6;color:#4527a0;}
.file-name{font-size:12px;font-weight:500;color:#1a237e;flex:1;}
.file-meta{font-size:10px;color:#90a4ae;margin-top:1px;}
.dl-btn{background:none;border:1px solid #90caf9;border-radius:7px;padding:4px 10px;font-size:11px;cursor:pointer;color:#1976d2;display:flex;align-items:center;gap:4px;white-space:nowrap;text-decoration:none;font-weight:500;}
.dl-btn.dim{opacity:.35;cursor:not-allowed;pointer-events:none;}
.team-label{font-size:10px;letter-spacing:.8px;text-transform:uppercase;color:#90a4ae;margin:12px 0 7px 2px;font-weight:600;}
.team-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:7px;}
.contact-card{background:#fff;border:1px solid #e3f2fd;border-radius:10px;padding:11px 13px;display:flex;gap:9px;align-items:flex-start;}
.av{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:#fff;flex-shrink:0;}
.c-name{font-size:12px;font-weight:600;color:#1a237e;}.c-role{font-size:10px;color:#90a4ae;margin-top:1px;}
.island-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(185px,1fr));gap:8px;}
.island{background:#fff;border:1px solid #e3f2fd;border-radius:12px;overflow:hidden;}
.island-head{padding:10px 13px 8px;border-bottom:1px solid #f0f4f8;}
.island-strat{font-size:9px;letter-spacing:.8px;text-transform:uppercase;font-weight:600;margin-bottom:3px;}
.island-name{font-size:12px;font-weight:600;color:#1a237e;}
.island-prods{padding:9px 13px;display:flex;flex-direction:column;gap:4px;}
.prod-row{display:flex;align-items:center;gap:6px;font-size:11px;color:#607d8b;}
.prod-dot{width:5px;height:5px;border-radius:50%;background:#4caf50;flex-shrink:0;}
.mkt-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:8px;margin-bottom:14px;}
.mkt-stat{background:#fff;border:1px solid #e3f2fd;border-radius:10px;padding:11px 13px;border-top:3px solid #ffc107;}
.mkt-lbl{font-size:9px;letter-spacing:.8px;text-transform:uppercase;color:#90a4ae;margin-bottom:3px;}
.mkt-val{font-size:22px;font-weight:600;color:#1a237e;}.mkt-sub{font-size:10px;color:#90a4ae;margin-top:1px;}
.speech{background:#e3f2fd;border-left:4px solid #1976d2;border-radius:0 8px 8px 0;padding:11px 14px;margin-bottom:12px;}
.speech-title{font-size:10px;letter-spacing:.8px;text-transform:uppercase;color:#1565c0;margin-bottom:5px;font-weight:600;}
.speech-body{font-size:12px;color:#1a237e;line-height:1.7;}
.lp-card{background:#fff;border:1px solid #e3f2fd;border-radius:12px;overflow:hidden;margin-bottom:12px;}
.lp-card-head{background:linear-gradient(135deg,#1565c0,#29b6f6);padding:14px 16px;}
.lp-card-title{font-size:13px;font-weight:600;color:#fff;margin-bottom:2px;}
.lp-card-sub{font-size:11px;color:rgba(255,255,255,.7);}
.lp-card-body{padding:16px;}
.lp-link-section{background:#f0f4f8;border:1px solid #e3f2fd;border-radius:10px;padding:14px;}
.lp-link-label{font-size:11px;font-weight:600;color:#607d8b;margin-bottom:8px;display:flex;align-items:center;gap:6px;}
.lp-link-label i{font-size:13px;color:#1976d2;}
.lp-open-btn{background:linear-gradient(135deg,#1976d2,#29b6f6);color:#fff;border:none;padding:10px 18px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;width:100%;justify-content:center;margin-top:10px;text-decoration:none;}
.lp-no-link{font-size:12px;color:#90a4ae;text-align:center;padding:10px;}
.empty-state{text-align:center;padding:28px;}
.empty-state i{font-size:26px;color:#b0bec5;display:block;margin-bottom:7px;}
.empty-state p{font-size:12px;color:#90a4ae;line-height:1.6;}
</style>
</head>
<body>
<div class="app">
<div class="topbar"><div><div class="brand-name">LAS<em>FOR</em>LIFE</div><div class="brand-tag">Transformando a Indústria da Doença em Indústria da Saúde</div></div></div>
<div class="screen active" id="homeScreen">
  <div class="home-hero">
    <div class="home-eyebrow">Articular o Sistema</div>
    <div class="home-title">Olá, equipe</div>
    <div class="home-sub">Escolha o evento para ver todas as informações</div>
    <div class="filter-row">
      <button class="filter-pill active" onclick="fBy('todos',this)">Todos</button>
      <button class="filter-pill" onclick="fBy('ativo',this)">Em andamento</button>
      <button class="filter-pill" onclick="fBy('próximo',this)">Próximos</button>
      <button class="filter-pill" onclick="fBy('encerrado',this)">Encerrados</button>
    </div>
  </div>
  <div class="events-wrap" id="eGrid"></div>
</div>
<div class="screen" id="detailScreen">
  <div class="detail-topbar">
    <button class="back-btn" onclick="gHome()"><i class="ti ti-arrow-left"></i> Eventos</button>
    <div class="detail-ev-name" id="dTitle"></div>
  </div>
  <div class="tab-bar" id="tBar"></div>
  <div id="tContent"></div>
</div>
</div>
<script>
var DB=JSON.parse(decodeURIComponent(escape(atob(""))));
var cf='todos',ce=null,ct='visao';
var TC=['#1e2235','#15803d','#1d4ed8','#7c3aed','#b45309','#be185d'];
var SA={ativo:'#4caf50','próximo':'#3b82f6',encerrado:'#9ca3af'};
var IC={'Medicina Regenerativa':{bg:'#f0fdf4',tc:'#15803d'},'Ortopedia / Infecção':{bg:'#fef2f2',tc:'#b91c1c'},'Ortopedia / Infecção Ortopédica':{bg:'#fef2f2',tc:'#b91c1c'},'Géis Antifibróticos + Neomedic':{bg:'#eff6ff',tc:'#1d4ed8'},'CCP — Inovação':{bg:'#f5f3ff',tc:'#6d28d9'},'Ilha do Giro':{bg:'#fffbeb',tc:'#92400e'}};
function sInfo(s){var l=(s||'').toLowerCase().trim();if(l==='ativo')return{c:'s-ativo',lb:'Em andamento'};if(l==='próximo'||l==='proximo')return{c:'s-proximo',lb:'Próximo'};return{c:'s-enc',lb:'Encerrado'};}
function fBy(f,btn){cf=f;document.querySelectorAll('.filter-pill').forEach(function(b){b.classList.remove('active');});btn.classList.add('active');rEv();}
function rEv(){var list=DB.eventos.filter(function(e){if(!e.nome)return false;if(cf==='todos')return true;var l=(e.status||'').toLowerCase().trim();if(cf==='ativo')return l==='ativo';if(cf==='próximo')return l==='próximo'||l==='proximo';return l==='encerrado';});var g=document.getElementById('eGrid');if(!list.length){g.innerHTML='<div class="empty-state"><i class="ti ti-calendar-off"></i><p>Nenhum evento encontrado.</p></div>';return;}g.innerHTML=list.map(function(e){var s=sInfo(e.status);var ac=SA[(e.status||'').toLowerCase().trim()]||'#9ca3af';return'<div class="event-card" onclick="oEv(\''+e.id+'\')">'+'<div class="ec-inner"><div class="ec-accent" style="background:'+ac+'"></div>'+'<div class="ec-main">'+'<div class="ec-top"><span class="ev-status '+s.c+'">'+s.lb+'</span><i class="ti ti-arrow-right ec-arrow"></i></div>'+'<div class="ec-name">'+e.nome+'</div>'+'<div class="ec-meta">'+'<div class="ec-meta-row"><i class="ti ti-calendar"></i>'+(e.data||'—')+'</div>'+'<div class="ec-meta-row"><i class="ti ti-map-pin"></i>'+(e.local||'—')+'</div>'+'<div class="ec-meta-row"><i class="ti ti-users"></i>'+(e.equipe||'—')+'</div>'+'</div>'+'<div class="ec-footer">'+'<div><div class="leads-lbl">Meta</div><div class="leads-val">'+(e.meta||'0')+' leads</div></div>'+'<div class="open-btn">Abrir <i class="ti ti-arrow-right"></i></div>'+'</div></div></div></div>';}).join('');}
var TABS=[{id:'visao',icon:'ti-layout-dashboard',label:'Visão geral'},{id:'agenda',icon:'ti-calendar',label:'Agenda'},{id:'materiais',icon:'ti-file-download',label:'Materiais'},{id:'equipe',icon:'ti-users',label:'Equipe'},{id:'produtos',icon:'ti-vaccine-bottle',label:'Produtos'},{id:'mkt',icon:'ti-speakerphone',label:'MKT'},{id:'leads',icon:'ti-forms',label:'Leads'}];
function oEv(id){ce=DB.eventos.find(function(e){return e.id===id;});if(!ce)return;ct='visao';document.getElementById('homeScreen').classList.remove('active');document.getElementById('detailScreen').classList.add('active');document.getElementById('dTitle').textContent=ce.nome;document.getElementById('tBar').innerHTML=TABS.map(function(t){return'<button class="tab-btn'+(t.id==='visao'?' active':'')+'" onclick="sTab(\''+t.id+'\',this)"><i class="ti '+t.icon+'"></i>'+t.label+'</button>';}).join('');rTab('visao');}
function gHome(){document.getElementById('detailScreen').classList.remove('active');document.getElementById('homeScreen').classList.add('active');}
function sTab(id,btn){ct=id;document.querySelectorAll('#tBar .tab-btn').forEach(function(b){b.classList.remove('active');});btn.classList.add('active');rTab(id);}
function rTab(id){var ev=ce,eid=ev.id,h='';
if(id==='visao'){var s=sInfo(ev.status);h='<div class="hero-block"><div class="hero-eyebrow">'+s.lb.toLowerCase()+'</div><div class="hero-name">'+ev.nome+'</div><div class="hero-pills"><span class="hpill hp-g"><i class="ti ti-calendar" style="font-size:10px;margin-right:3px"></i>'+(ev.data||'')+'</span><span class="hpill hp-b"><i class="ti ti-map-pin" style="font-size:10px;margin-right:3px"></i>'+(ev.local||'')+'</span>'+(ev.stand?'<span class="hpill hp-y">'+ev.stand+'</span>':'')+'</div></div><div class="stat-grid"><div class="stat"><div class="stat-lbl">Data</div><div class="stat-val" style="font-size:13px">'+(ev.data||'—')+'</div></div><div class="stat"><div class="stat-lbl">Local</div><div class="stat-val" style="font-size:12px">'+(ev.local||'—').split(',')[0]+'</div></div><div class="stat"><div class="stat-lbl">Meta</div><div class="stat-val">'+(ev.meta||'—')+'</div><div class="stat-sub">leads</div></div><div class="stat"><div class="stat-lbl">👥 Equipe</div><div class="stat-val" style="font-size:12px">'+(ev.equipe||'—')+'</div></div></div>'+(ev.orientacoes?'<div class="iblock"><div class="iblock-head"><i class="ti ti-alert-circle"></i> Orientações gerais</div><div class="iblock-body">'+ev.orientacoes+'</div></div>':'');}
else if(id==='agenda'){var ag=DB.agenda.filter(function(a){return a.evento_id===eid;});if(!ag.length){h='<div class="empty-state"><i class="ti ti-calendar-off"></i><p>Nenhum item de agenda.</p></div>';}else{var bm={Cocktail:'mb-y','Ativação':'mb-p','Stand LAS':'mb-g',Convite:'mb-b'};h='<div class="ag-list">'+ag.map(function(a){var b=a.badge?'<span class="mbadge '+(bm[a.badge]||'mb-b')+'">'+a.badge+'</span>':'';var las=a.destaque==='Sim'?'<span class="mbadge mb-g">LAS</span>':'';return'<div class="ag-item"><span class="ag-day">'+(a.dia||'').replace(' ','<br/>')+'</span><div><div class="ag-title">'+(a.atividade||'')+las+'</div><div class="ag-loc"><i class="ti ti-map-pin"></i>'+(a.local||'')+b+'</div>'+(a.horario?'<div class="ag-loc" style="margin-top:2px"><i class="ti ti-clock"></i>'+a.horario+'</div>':'')+'</div></div>';}).join('')+'</div>';}}
else if(id==='materiais'){var mt=DB.materiais.filter(function(m){return m.evento_id===eid&&m.ativo!=='Não'&&m.nome;});if(!mt.length){h='<div class="empty-state"><i class="ti ti-file-off"></i><p>Nenhum material ainda.</p></div>';}else{var cs=[];mt.forEach(function(m){if(m.categoria&&cs.indexOf(m.categoria)<0)cs.push(m.categoria);});if(!cs.length)cs=['Geral'];var im={PDF:'fi-pdf',PPT:'fi-ppt',XLS:'fi-xls','Vídeo':'fi-vid',Doc:'fi-doc',ZIP:'fi-zip'};var ic={PDF:'file-type-pdf',PPT:'presentation',XLS:'table','Vídeo':'player-play',Doc:'file',ZIP:'file-zip'};h=cs.map(function(cat){var cm=cat==='Geral'?mt:mt.filter(function(m){return m.categoria===cat;});if(!cm.length)return'';return'<div class="mat-cat">'+cat+'</div><div class="file-list">'+cm.map(function(m){var fc=im[m.tipo]||'fi-doc',fi=ic[m.tipo]||'file';var hf=m.arquivo_base64&&m.arquivo_base64.length>100;var hl=m.link&&m.link!=='';var iv=m.tipo==='Vídeo';var db='<span class="dl-btn dim"><i class="ti ti-clock"></i> Em breve</span>';if(hf){db='<a href="'+m.arquivo_base64+'" download="'+(m.arquivo_nome||m.nome)+'" class="dl-btn"><i class="ti ti-download"></i> Baixar</a>';}else if(hl){if(iv){db='<a href="'+m.link+'" target="_blank" class="dl-btn"><i class="ti ti-external-link"></i> Abrir</a>';}else{db='<button class="dl-btn" onclick="dlLink(''+m.link+'',''+encodeURIComponent(m.arquivo_nome||m.nome||'arquivo')+'')"><i class="ti ti-download"></i> Baixar</button>';}}return'<div class="file-row"><div class="ficon '+fc+'"><i class="ti ti-'+fi+'"></i></div><div style="flex:1"><div class="file-name">'+m.nome+'</div><div class="file-meta">'+(m.tipo||'')+(m.data?' · '+m.data:'')+'</div></div>'+db+'</div>';}).join('')+'</div>';}).join('');}}
else if(id==='equipe'){var mb=DB.equipe.filter(function(p){return p.evento_id===eid&&p.nome;});if(!mb.length){h='<div class="empty-state"><i class="ti ti-users-off"></i><p>Nenhuma escala cadastrada.</p></div>';}else{var ds=[];mb.forEach(function(p){var d=p.dia||'Sem data';if(ds.indexOf(d)<0)ds.push(d);});var TC2={'Dia todo':'#1976d2','Manhã':'#ffc107','Tarde':'#4caf50','Noite':'#7b1fa2','Manhã e Tarde':'#e65100'};var FI={'Stand':'ti-home','Vendas':'ti-currency-dollar','Coordenação':'ti-star','Suporte':'ti-headset','Palestra':'ti-microphone','Demonstração':'ti-presentation','Outro':'ti-user'};h='<div style="margin-bottom:8px;background:#e3f2fd;border-radius:8px;padding:9px 13px;font-size:12px;color:#1565c0;display:flex;align-items:center;gap:6px;"><i class=\"ti ti-users\"></i> <strong>'+mb.length+'</strong> pessoas na escala</div>'+ds.map(function(dia){var gr=mb.filter(function(p){return(p.dia||'Sem data')===dia;});return'<div style="background:#fff;border:1px solid #e3f2fd;border-radius:12px;overflow:hidden;margin-bottom:10px;"><div style="background:#1976d2;padding:9px 14px;display:flex;align-items:center;gap:8px;"><i class=\"ti ti-calendar\" style=\"color:#fff;font-size:14px\"></i><span style=\"font-size:13px;font-weight:600;color:#fff\">'+dia+'</span><span style=\"font-size:10px;background:rgba(255,255,255,.2);color:#fff;padding:2px 8px;border-radius:20px;margin-left:auto\">'+gr.length+' pessoas</span></div><div style=\"display:flex;flex-direction:column;gap:1px;padding:8px\">'+gr.map(function(p,i){var ini=p.nome.split(' ').map(function(n){return n[0]||'';}).join('').toUpperCase().slice(0,2);var tc=TC2[p.turno]||'#607d8b';var fi=FI[p.funcao]||'ti-user';return'<div style=\"display:flex;align-items:center;gap:10px;padding:8px 6px;border-radius:8px;background:'+(i%2===0?'#f8fbff':'#fff')+';\"><div style=\"width:32px;height:32px;border-radius:50%;background:'+TC[i%TC.length]+';color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;flex-shrink:0\">'+ini+'</div><div style=\"flex:1\"><div style=\"font-size:12px;font-weight:600;color:#1a237e\">'+p.nome+'</div><div style=\"display:flex;align-items:center;gap:6px;margin-top:3px;flex-wrap:wrap\">'+(p.turno?'<span style=\"font-size:10px;font-weight:600;padding:1px 7px;border-radius:20px;background:'+tc+'20;color:'+tc+'\">'+p.turno+'</span>':'')+(p.funcao?'<span style=\"font-size:10px;color:#607d8b\"><i class=\"ti '+fi+'\" style=\"font-size:11px\"></i>'+p.funcao+'</span>':'')+(p.obs?'<span style=\"font-size:10px;color:#90a4ae\">'+p.obs+'</span>':'')+'</div></div>'+(p.telefone?'<a href=\"tel:'+p.telefone+'\" style=\"font-size:10px;color:#1976d2;text-decoration:none\"><i class=\"ti ti-phone\" style=\"font-size:12px\"></i></a>':'')+'</div>';}).join('')+'</div></div>';}).join('');}}
else if(id==='produtos'){var pr=DB.produtos.filter(function(p){return p.evento_id===eid&&p.produto;});if(!pr.length){h='<div class="empty-state"><i class="ti ti-vaccine-bottle"></i><p>Nenhum produto.</p></div>';}else{var il=[];pr.forEach(function(p){if(p.especialidade&&il.indexOf(p.especialidade)<0)il.push(p.especialidade);});h='<div class="island-grid">'+il.map(function(esp){var ip=pr.filter(function(p){return p.especialidade===esp;});var ico=IC[esp]||{bg:'#f9fafb',tc:'#6b7280'};var st=ip[0].estrategia||'';return'<div class="island"><div class="island-head" style="background:'+ico.bg+'"><div class="island-strat" style="color:'+ico.tc+'">'+st+'</div><div class="island-name">'+esp+'</div></div><div class="island-prods">'+ip.map(function(p){return'<div class="prod-row"><div class="prod-dot"'+(p.destaque!=='Sim'?' style="background:#d1d5db"':'')+' ></div>'+p.produto+'</div>';}).join('')+'</div></div>';}).join('')+'</div>';}}
else if(id==='mkt'){var mr=DB.mkt.find(function(m){return m.evento_id===eid;});if(!mr){h='<div class="empty-state"><i class="ti ti-speakerphone"></i><p>Nenhuma info de MKT.</p></div>';}else{h='<div class="mkt-grid"><div class="mkt-stat"><div class="mkt-lbl">Meta total</div><div class="mkt-val">'+(mr.meta||'—')+'</div><div class="mkt-sub">leads</div></div><div class="mkt-stat"><div class="mkt-lbl">Benchmark</div><div class="mkt-val">6–7</div><div class="mkt-sub">leads/pessoa/dia</div></div></div>'+(mr.dress_code?'<div class="iblock"><div class="iblock-head"><i class="ti ti-shirt"></i> Dress code</div><div class="iblock-body">'+mr.dress_code+'</div></div>':'')+(mr.campanhas?'<div class="iblock"><div class="iblock-head"><i class="ti ti-discount-2"></i> Campanhas</div><div class="iblock-body">'+mr.campanhas+'</div></div>':'')+(mr.acoes?'<div class="iblock"><div class="iblock-head"><i class="ti ti-star"></i> Ações especiais</div><div class="iblock-body">'+mr.acoes+'</div></div>':'')+(mr.mensagens?'<div class="iblock"><div class="iblock-head"><i class="ti ti-message-circle"></i> Mensagens-chave</div><div class="iblock-body">'+mr.mensagens+'</div></div>':'');}}
else if(id==='leads'){var lpr=DB.leads_lp.find(function(l){return l.evento_id===eid;});var lpl=lpr?lpr.link:'';h='<div class="lp-card"><div class="lp-card-head"><div class="lp-card-title">'+ev.nome+'</div><div class="lp-card-sub">Landing page de captura de leads</div></div><div class="lp-card-body"><div class="lp-link-section"><div class="lp-link-label"><i class="ti ti-link"></i> LP deste evento</div>'+(lpl?'<a href="'+lpl+'" target="_blank" class="lp-open-btn"><i class="ti ti-external-link"></i> Abrir LP de captação</a>':'<div class="lp-no-link">Nenhum link configurado.</div>')+'</div></div></div><div class="speech"><div class="speech-title">Speech no stand</div><div class="speech-body">1. Qual dor? — Identifique o problema do visitante<br/>2. Qual produto encaixa? — Conecte à especialidade correta<br/>3. Qual o próximo passo? — Direcione para a LP ou feche pedido</div></div>';}
document.getElementById('tContent').innerHTML='<div class="tab-content active">'+h+'</div>';}

function dlLink(url,encodedName){
  var nome=decodeURIComponent(encodedName);
  fetch(url)
    .then(function(r){if(!r.ok)throw new Error('fetch');return r.blob();})
    .then(function(blob){var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=nome;document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(a.href);})
    .catch(function(){window.open(url,'_blank');});
}
window.addEventListener('DOMContentLoaded',function(){rEv();});
</script>
</body>
</html>
